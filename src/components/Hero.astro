---
const slides = [
    {
        src: "https://mir-s3-cdn-cf.behance.net/projects/808/105660160763715.Y3JvcCwyNjI0LDIwNTIsMCwyNDA.jpg",
        category: "Retrato Editorial",
        line1: "El Arte",
        line2: "de Mirar",
    },
    {
        src: "https://mir-s3-cdn-cf.behance.net/projects/808/d28ecc245385351.Y3JvcCw0Mjk3LDMzNjEsMCw0MzY.jpg",
        category: "Cultura & Identidad",
        line1: "Raíces",
        line2: "Vivas",
    },
    {
        src: "https://mir-s3-cdn-cf.behance.net/projects/808/9f0124117126749.Y3JvcCwxNzIzLDEzNDcsMCw2MjY.jpg",
        category: "Estilo Personal",
        line1: "Luz y",
        line2: "Silencio",
    },
];
---

<section id="home" class="relative h-screen w-full overflow-hidden bg-black">
    <!-- Carousel slides (stacked, crossfade) -->
    <div class="absolute inset-0">
        {
            slides.map((slide, i) => (
                <div class={`carousel-slide absolute inset-0 ${i === 0 ? "is-active" : ""}`}>
                    <img
                        src={slide.src}
                        alt={slide.category}
                        class="carousel-img h-full w-full object-cover"
                        fetchpriority={i === 0 ? "high" : "low"}
                        loading={i === 0 ? "eager" : "lazy"}
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/25 to-black/15" />
                    <div class="absolute inset-0 bg-gradient-to-r from-black/65 via-black/10 to-transparent" />
                </div>
            ))
        }
    </div>

    <!-- Navigation -->
    <nav
        id="main-nav"
        class="fixed left-0 right-0 top-0 z-30 flex items-center justify-between px-8 py-10 md:px-16 md:py-12"
    >
        <a href="/" class="font-display text-base tracking-[0.45em] text-white uppercase font-light"> David Tapuy </a>
        <ul class="hidden items-center gap-10 md:flex">
            <li>
                <a
                    href="#work"
                    class="text-[10px] tracking-[0.25em] text-white/60 uppercase transition-colors duration-300 hover:text-white font-light"
                    >Trabajo</a>
            </li>
            <li>
                <a
                    href="#about"
                    class="text-[10px] tracking-[0.25em] text-white/60 uppercase transition-colors duration-300 hover:text-white font-light"
                    >Sobre mí</a>
            </li>
            <li>
                <a
                    href="#contact"
                    class="text-[10px] tracking-[0.25em] text-white/60 uppercase transition-colors duration-300 hover:text-white font-light"
                    >Contacto</a>
            </li>
        </ul>
        <button
            id="menuBtn"
            aria-label="Abrir menú"
            class="md:hidden text-white/60 hover:text-white transition-colors duration-300"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
            >
                <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h10"></path>
            </svg>
        </button>
    </nav>

    <!-- Mobile menu overlay -->
    <div id="mobileMenu" class="fixed inset-0 z-50 hidden flex-col items-center justify-center bg-black/96">
        <button
            id="closeMenu"
            aria-label="Cerrar menú"
            class="absolute right-8 top-8 text-white/50 hover:text-white transition-colors duration-300"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
            >
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>
        <nav class="flex flex-col items-center gap-10">
            <a
                href="#work"
                class="mobile-link font-display text-4xl text-white/80 italic font-light hover:text-white transition-colors duration-300"
                >Trabajo</a
            >
            <a
                href="#about"
                class="mobile-link font-display text-4xl text-white/80 italic font-light hover:text-white transition-colors duration-300"
                >Sobre mí</a
            >
            <a
                href="#contact"
                class="mobile-link font-display text-4xl text-white/80 italic font-light hover:text-white transition-colors duration-300"
                >Contacto</a
            >
        </nav>
    </div>

    <!-- Text overlay (transitions independently) -->
    <div id="hero-text" class="absolute inset-0 z-20 flex flex-col justify-end px-8 pb-24 md:px-16 md:pb-32">
        <p id="slide-category" class="mb-5 text-[9px] tracking-[0.45em] text-white/45 uppercase font-light">
            {slides[0].category}
        </p>
        <h1 class="font-display font-light text-white leading-[0.87]">
            <span id="slide-line1" class="block text-[clamp(3.5rem,9vw,9.5rem)]">{slides[0].line1}</span>
            <span id="slide-line2" class="block text-[clamp(3.5rem,9vw,9.5rem)] italic text-white/70 md:pl-[6vw]"
                >{slides[0].line2}</span
            >
        </h1>
        <p class="mt-8 text-white/35 text-xs tracking-widest font-light">Narrativa visual que trasciende el instante</p>
    </div>

    <!-- Slide counter -->
    <div class="absolute bottom-10 left-8 z-30 md:left-16">
        <span id="slide-counter" class="text-[9px] tracking-[0.35em] text-white/30 uppercase font-light">
            01 / 0{slides.length}
        </span>
    </div>

    <!-- Dot navigation -->
    <div class="absolute bottom-10 left-1/2 z-30 flex -translate-x-1/2 items-center gap-2">
        {
            slides.map((_, i) => (
                <button
                    class={`carousel-dot ${i === 0 ? "is-active" : ""}`}
                    data-index={String(i)}
                    aria-label={`Ir a slide ${i + 1}`}
                />
            ))
        }
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-10 right-8 z-30 flex items-center gap-3 md:right-16">
        <span class="text-[8px] tracking-[0.45em] text-white/30 uppercase font-light">Scroll</span>
        <div class="h-px w-10 bg-white/15"></div>
    </div>
</section>

<style>
    /* ── Carousel crossfade ── */
    .carousel-slide {
        opacity: 0;
        transition: opacity 1.8s cubic-bezier(0.4, 0, 0.2, 1);
        will-change: opacity;
    }
    .carousel-slide.is-active {
        opacity: 1;
    }

    /* ── Ken Burns on active slide image ── */
    .carousel-slide.is-active .carousel-img {
        animation: kenburns 9s ease-out forwards;
    }
    @keyframes kenburns {
        from {
            transform: scale(1.08);
        }
        to {
            transform: scale(1);
        }
    }

    /* ── Nav scroll effect ── */
    #main-nav {
        transition: padding 0.5s ease;
    }
    #main-nav.is-scrolled {
        padding-top: 1.1rem;
        padding-bottom: 1.1rem;
    }

    /* ── Text layer transition ── */
    #hero-text {
        transition:
            opacity 0.45s ease,
            transform 0.45s ease;
    }

    /* ── Dot navigation ── */
    .carousel-dot {
        height: 2px;
        width: 18px;
        background: rgba(255, 255, 255, 0.22);
        border: none;
        padding: 0;
        cursor: pointer;
        border-radius: 2px;
        transition:
            width 0.4s ease,
            background 0.4s ease;
    }
    .carousel-dot.is-active {
        width: 36px;
        background: rgba(255, 255, 255, 0.85);
    }
    .carousel-dot:hover {
        background: rgba(255, 255, 255, 0.5);
    }
</style>

<script define:vars={{ slidesData: slides }}>
    const carouselEls = document.querySelectorAll(".carousel-slide");
    const dotEls = document.querySelectorAll(".carousel-dot");
    const heroText = document.getElementById("hero-text");
    const categoryEl = document.getElementById("slide-category");
    const line1El = document.getElementById("slide-line1");
    const line2El = document.getElementById("slide-line2");
    const counterEl = document.getElementById("slide-counter");

    let current = 0;
    let ticker = null;
    const DELAY = 6000;
    const total = carouselEls.length;

    function pad(n) {
        return String(n + 1).padStart(2, "0");
    }

    function goTo(index) {
        if (index === current) return;

        // Fade text out + slight upward drift
        heroText.style.opacity = "0";
        heroText.style.transform = "translateY(10px)";

        // Crossfade image
        carouselEls[current].classList.remove("is-active");
        dotEls[current].classList.remove("is-active");

        current = index;

        carouselEls[current].classList.add("is-active");
        dotEls[current].classList.add("is-active");

        // After text fades out → update content → fade back in
        setTimeout(() => {
            categoryEl.textContent = slidesData[current].category;
            line1El.textContent = slidesData[current].line1;
            line2El.textContent = slidesData[current].line2;
            counterEl.textContent = `${pad(current)} / ${pad(total - 1)}`;

            heroText.style.opacity = "1";
            heroText.style.transform = "translateY(0)";
        }, 480);
    }

    function next() {
        goTo((current + 1) % total);
    }

    function startTicker() {
        ticker = setInterval(next, DELAY);
    }

    function resetTicker() {
        clearInterval(ticker);
        startTicker();
    }

    startTicker();

    dotEls.forEach((dot, i) => {
        dot.addEventListener("click", () => {
            goTo(i);
            resetTicker();
        });
    });

    // Nav scroll effect — progressive fade 0 → 0.88 over 350px
    const mainNav = document.getElementById("main-nav");
    window.addEventListener(
        "scroll",
        () => {
            const ratio = Math.min(window.scrollY / 350, 1);
            const opacity = (ratio * 0.88).toFixed(3);
            const blur = (ratio * 10).toFixed(1);
            if (mainNav) {
                mainNav.style.background = `rgba(0, 0, 0, ${opacity})`;
                mainNav.style.backdropFilter = ratio > 0.05 ? `blur(${blur}px)` : "none";
                mainNav.style.webkitBackdropFilter = ratio > 0.05 ? `blur(${blur}px)` : "none";
            }
            if (window.scrollY > 60) {
                mainNav?.classList.add("is-scrolled");
            } else {
                mainNav?.classList.remove("is-scrolled");
            }
        },
        { passive: true },
    );

    // Mobile menu
    const menuBtn = document.getElementById("menuBtn");
    const closeMenu = document.getElementById("closeMenu");
    const mobileMenu = document.getElementById("mobileMenu");
    const mobileLinks = document.querySelectorAll(".mobile-link");

    menuBtn?.addEventListener("click", () => {
        mobileMenu?.classList.remove("hidden");
        mobileMenu?.classList.add("flex");
    });

    function closeMobileMenu() {
        mobileMenu?.classList.add("hidden");
        mobileMenu?.classList.remove("flex");
    }

    closeMenu?.addEventListener("click", closeMobileMenu);
    mobileLinks.forEach((l) => l.addEventListener("click", closeMobileMenu));
</script>
