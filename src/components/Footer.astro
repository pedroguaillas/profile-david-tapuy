---
const igImages = [
  {
    src: 'https://mir-s3-cdn-cf.behance.net/projects/808/9f0124117126749.Y3JvcCwxNzIzLDEzNDcsMCw2MjY.jpg',
    alt: 'Fotografía estilo personal',
  },
  {
    src: 'https://mir-s3-cdn-cf.behance.net/projects/808/45a4f4160763591.Y3JvcCwxOTQ2LDE1MjIsMCwyMTE.jpg',
    alt: 'Portrait personal Davidos',
  },
  {
    src: 'https://mir-s3-cdn-cf.behance.net/projects/808/134eae139622385.Y3JvcCwyNjI0LDIwNTIsMCw5NDE.jpg',
    alt: 'En el Chimborazo',
  },
];

const bhImages = [
  {
    src: 'https://mir-s3-cdn-cf.behance.net/projects/808/b1e95b245383323.Y3JvcCwzMzc2LDI2NDAsMCw5ODY.jpg',
    alt: 'Nacionalidad Shuar',
  },
  {
    src: 'https://mir-s3-cdn-cf.behance.net/project_modules/1400_webp/ff8fba160763715.63ba41987b1ba.jpg',
    alt: 'Retrato elegante',
  },
  {
    src: 'https://mir-s3-cdn-cf.behance.net/projects/808/84c9f972874257.Y3JvcCw0MTcyLDMyNjQsMzgyLDA.jpg',
    alt: 'Foto Musik',
  },
];
---

<footer id="contact" class="bg-black text-white">

  <!-- Statement + contact -->
  <div class="px-8 pt-24 pb-16 md:px-16 md:pt-32 md:pb-20">
    <div class="mx-auto max-w-7xl flex flex-col md:flex-row md:items-end md:justify-between gap-10">

      <div>
        <p class="mb-6 text-[9px] tracking-[0.45em] text-white/60 uppercase font-light">Contacto</p>
        <h2 class="font-display font-light leading-[0.88]">
          <span class="block text-[clamp(2.8rem,6vw,7rem)]">Trabajemos</span>
          <span class="block text-[clamp(2.8rem,6vw,7rem)] italic text-white/65">juntos</span>
        </h2>
      </div>

      <div class="flex flex-col gap-3 md:text-right">
        <a href="mailto:david@tapuy.com" class="text-sm text-white/80 hover:text-white transition-colors duration-300 font-light tracking-wide">
          david@tapuy.com
        </a>
        <p class="text-sm text-white/50 font-light">Quito, Ecuador</p>
      </div>

    </div>
  </div>

  <!-- Photo strip -->
  <div class="px-8 pb-16 md:px-16">
    <div class="mx-auto max-w-7xl">

      <!-- Label row -->
      <div class="grid grid-cols-2 gap-4 mb-4">
        <p class="text-[8px] tracking-[0.4em] text-white/35 uppercase font-light">Instagram</p>
        <p class="text-[8px] tracking-[0.4em] text-white/35 uppercase font-light">Behance</p>
      </div>

      <!-- 6-photo grid -->
      <div class="grid grid-cols-3 md:grid-cols-6 gap-1.5 mb-5">

        <!-- Instagram x3 -->
        {igImages.map((img) => (
          <a
            href="https://www.instagram.com/davidos_ph/"
            target="_blank"
            rel="noopener noreferrer"
            class="group relative aspect-square overflow-hidden bg-neutral-900 block"
          >
            <img
              src={img.src}
              alt={img.alt}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-black/0 transition-all duration-400 group-hover:bg-black/30 flex items-center justify-center">
              <svg class="w-6 h-6 text-white opacity-0 transition-opacity duration-400 group-hover:opacity-100" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </div>
          </a>
        ))}

        <!-- Behance x3 -->
        {bhImages.map((img) => (
          <a
            href="https://www.behance.net/eldavidos"
            target="_blank"
            rel="noopener noreferrer"
            class="group relative aspect-square overflow-hidden bg-neutral-900 block"
          >
            <img
              src={img.src}
              alt={img.alt}
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
            <div class="absolute inset-0 bg-black/0 transition-all duration-400 group-hover:bg-black/30 flex items-center justify-center">
              <svg class="w-6 h-6 text-white opacity-0 transition-opacity duration-400 group-hover:opacity-100" viewBox="0 0 24 24" fill="currentColor">
                <path d="M22 7h-7V5h7v2zm1.726 10c-.442 1.297-2.029 3-5.101 3-3.074 0-5.564-1.729-5.564-5.675 0-3.91 2.325-5.92 5.466-5.92 3.082 0 4.964 1.782 5.375 4.426.078.506.109 1.188.095 2.14H15.97c.13 1.202.483 1.88 1.358 2.354.604.33 1.383.415 2.161.225.513 0 1.026-.06 1.539-.18l.548 1.18zm-7.18-5.975c-.499.04-.963.235-1.338.594-.388.37-.596.87-.596 1.398H17.9c-.107-1.327-.746-2-1.354-2zM4.046 18H.599V5h4.147C7.1 5 9 5.904 9 8.192c0 1.316-.577 2.178-1.543 2.697C8.807 11.386 9.5 12.4 9.5 13.938 9.5 16.639 7.531 18 4.046 18zm-.505-7.975h-1.29v2.014h1.29c.794 0 1.346-.328 1.346-1.016 0-.686-.552-1-1.346-1zm.072 3.952H2.251v2.246h1.362c.93 0 1.437-.44 1.437-1.125 0-.685-.507-1.12-1.437-1.12z"/>
              </svg>
            </div>
          </a>
        ))}

      </div>

      <!-- Links row -->
      <div class="grid grid-cols-2 gap-4">
        <a
          href="https://www.instagram.com/davidos_ph/"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-3 text-[9px] tracking-[0.3em] text-white/50 uppercase hover:text-white transition-colors duration-300 font-light"
        >
          <span>Ver en Instagram</span>
          <div class="h-px w-6 bg-white/20 group-hover:w-10 group-hover:bg-white/60 transition-all duration-400"></div>
        </a>
        <a
          href="https://www.behance.net/eldavidos"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-3 text-[9px] tracking-[0.3em] text-white/50 uppercase hover:text-white transition-colors duration-300 font-light"
        >
          <span>Ver en Behance</span>
          <div class="h-px w-6 bg-white/20 group-hover:w-10 group-hover:bg-white/60 transition-all duration-400"></div>
        </a>
      </div>

    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10 px-8 py-6 md:px-16">
    <div class="flex items-center justify-between text-[8px] tracking-[0.35em] text-white/40 uppercase font-light">
      <span>© 2024 David Tapuy</span>
      <span>Fotografía de Autor — Ecuador</span>
    </div>
  </div>

</footer>

<!-- WhatsApp floating button -->
<a
  href="https://wa.me/593995482336"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Contactar por WhatsApp"
  class="whatsapp-btn"
>
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="26" height="26">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
    <path d="M12 0C5.373 0 0 5.373 0 12c0 2.117.554 4.103 1.523 5.824L.057 23.25a.75.75 0 00.916.928l5.565-1.453A11.953 11.953 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.907 0-3.7-.512-5.243-1.406l-.364-.214-3.77.985.999-3.676-.235-.38A9.96 9.96 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
  </svg>
</a>

<style>
  .whatsapp-btn {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 100;
    width: 54px;
    height: 54px;
    background: #25D366;
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.35);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .whatsapp-btn:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 28px rgba(37, 211, 102, 0.5);
  }
  .whatsapp-btn:active {
    transform: scale(0.96);
  }
</style>
