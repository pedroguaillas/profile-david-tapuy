---
---

<section id="about" class="bg-off-white py-24 md:py-40">
  <div class="px-8 md:px-16">
    <div class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-16 md:grid-cols-2 md:gap-28">

      <!-- Text — left on desktop -->
      <div class="md:pl-10 md:pr-4 order-2 md:order-1">
        <p class="mb-8 text-[9px] tracking-[0.45em] text-black/35 uppercase font-light">Sobre mí</p>

        <h2 class="font-display font-light leading-[0.9] mb-12">
          <span class="block text-[clamp(2.4rem,4.5vw,4.8rem)]">Creo que</span>
          <span class="block text-[clamp(2.4rem,4.5vw,4.8rem)] italic text-black/40">cada luz</span>
          <span class="block text-[clamp(2.4rem,4.5vw,4.8rem)]">cuenta una</span>
          <span class="block text-[clamp(2.4rem,4.5vw,4.8rem)] italic text-black/40">historia</span>
        </h2>

        <div class="space-y-5 text-sm text-black/55 font-light leading-loose max-w-sm">
          <p>
            Soy David Tapuy, fotógrafo de autor con base en Ecuador. Mi trabajo explora la tensión entre lo íntimo y lo universal, capturando retratos que trascienden el momento.
          </p>
          <p>
            Formado entre la fotografía de calle y el estudio editorial, mi lenguaje visual se construye sobre el silencio, la luz natural y la composición instintiva.
          </p>
          <p>
            Disponible para proyectos editoriales, retratos de autor y colaboraciones artísticas a nivel regional e internacional.
          </p>
        </div>

        <!-- Stats -->
        <dl class="mt-14 flex items-start gap-12 border-t border-black/8 pt-10">
          <div>
            <dt class="font-display text-[2.6rem] font-light leading-none">8+</dt>
            <dd class="mt-2 text-[8px] tracking-[0.35em] text-black/35 uppercase font-light">Años</dd>
          </div>
          <div>
            <dt class="font-display text-[2.6rem] font-light leading-none">200+</dt>
            <dd class="mt-2 text-[8px] tracking-[0.35em] text-black/35 uppercase font-light">Proyectos</dd>
          </div>
          <div>
            <dt class="font-display text-[2.6rem] font-light leading-none">∞</dt>
            <dd class="mt-2 text-[8px] tracking-[0.35em] text-black/35 uppercase font-light">Historias</dd>
          </div>
        </dl>
      </div>

      <!-- Image — right on desktop -->
      <div class="relative order-1 md:order-2">
        <div class="aspect-[3/4] overflow-hidden bg-neutral-200">
          <img
            src="https://instagram.fgye10-1.fna.fbcdn.net/v/t51.82787-15/611595790_18415878208140608_4579930317576123217_n.jpg?stp=dst-jpg_e35_tt6&_nc_cat=108&ig_cache_key=MzgwNDUzNDcwMDI1MDA0NjQ3NQ%3D%3D.3-ccb7-5&ccb=7-5&_nc_sid=58cdad&efg=eyJ2ZW5jb2RlX3RhZyI6IkNBUk9VU0VMX0lURU0ueHBpZHMuMTQ0MC5zZHIucmVndWxhcl9waG90by5DMyJ9&_nc_ohc=sLqym9UNZ1sQ7kNvwHWrKx7&_nc_oc=AdpzLgKkCagg0Q8SZB4nXcGPiSwd8ZGqHxqH4N6EtSvBN30WXG3N6PgiPQTUkXZwdNE&_nc_zt=23&_nc_ht=instagram.fgye10-1.fna&_nc_gid=O8Tc7hqgF0iPz7xj3QLoHQ&_nc_ss=7ba02&oh=00_Af-gxHVi_hZsl8j310jGFLZXKelICg9exeRu9KfIeWbySw&oe=6A35F41C"
            alt="David Tapuy, fotógrafo"
            class="h-full w-full object-cover"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="absolute -bottom-5 -left-5 h-28 w-28 border border-black/8"></div>
      </div>

    </div>
  </div>
</section>
